# Inventory Dashboard — environment variables
# Copy to .env.local for local dev; set the same keys in the Vercel project
# (Production + Preview). The database is Neon (COS production reader).

# -----------------------------------------------------------------------------
# COS production reader (REQUIRED)
# -----------------------------------------------------------------------------
# The cos_mcp_reader role: SELECT-only on the masked mcp.v_* views — the same
# role/credential the COS Database MCP uses. Get the connection string from the
# team. NEVER use a broader COS credential here. Use the POOLED Neon endpoint
# (…-pooler.…neon.tech). TLS is verified by default.
DATABASE_MCP_URL="postgresql://cos_mcp_reader:PASSWORD@host-pooler.neon.tech/WMS?sslmode=require"

# -----------------------------------------------------------------------------
# CORS / origin (REQUIRED in production)
# -----------------------------------------------------------------------------
# The dashboard's own origin, e.g. https://inventory-dashboard.vercel.app
# Scopes Access-Control-Allow-Origin so the data is not readable cross-site.
DASHBOARD_ORIGIN=""

# -----------------------------------------------------------------------------
# Access gate (IMPORTANT)
# -----------------------------------------------------------------------------
# This API is read-only and has no per-request auth. The production access gate
# is **Vercel Deployment Protection** (password or SSO) on the deployment —
# enable it before connecting production data. OFFICE_SECRET below is only used
# if/when a future write endpoint is added (light x-office-key check).
OFFICE_SECRET=""

# -----------------------------------------------------------------------------
# Optional tuning (sane defaults in code)
# -----------------------------------------------------------------------------
# Set to "disable" to turn off TLS for a local Postgres during testing.
# PGSSL=""
# COS_STATEMENT_TIMEOUT_MS=15000
# INVENTORY_CACHE_MS=55000
# FC_REGION=CA
