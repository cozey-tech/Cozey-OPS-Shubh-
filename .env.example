# Required: COS Neon pooled connection string (cos_mcp_reader role)
DATABASE_MCP_URL=postgresql://cos_mcp_reader:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/WMS?sslmode=require&channel_binding=require

# Required: App URL for CORS scoping — must match exactly
# Example: https://cozey-ops.vercel.app
DASHBOARD_ORIGIN=https://your-app-url.vercel.app

# Optional: Header secret for future write endpoints
# OFFICE_SECRET=your-secret-here

# Local dev only: set to 'disable' when using local Postgres without TLS
# PGSSL=disable
